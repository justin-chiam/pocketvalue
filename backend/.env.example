# Gemini is called through Vertex AI (GCP). Auth comes from Application Default
# Credentials — GOOGLE_APPLICATION_CREDENTIALS points at the service account's
# JSON key file. Drop the key at backend/keys/service-account.json
# (backend/keys/ is gitignored; never commit a key). The path is resolved
# relative to backend/, where npm runs.
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=./keys/service-account.json

PORT=3001
